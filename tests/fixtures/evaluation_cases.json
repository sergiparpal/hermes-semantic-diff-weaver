[
  {
    "name": "inclusive boundary",
    "old": "def allowed(x):\n    return x < 5\n",
    "new": "def allowed(x):\n    return x <= 5\n",
    "expected": ["boundary_change"]
  },
  {
    "name": "default argument",
    "old": "def run(limit=2):\n    return limit\n",
    "new": "def run(limit=3):\n    return limit\n",
    "expected": ["default_behavior_change"]
  },
  {
    "name": "exception type",
    "old": "def run():\n    raise ValueError()\n",
    "new": "def run():\n    raise TypeError()\n",
    "expected": ["error_handling_change"]
  },
  {
    "name": "retry predicate",
    "old": "def retry(attempts):\n    while attempts < 3:\n        attempts += 1\n    return attempts\n",
    "new": "def retry(attempts):\n    while attempts <= 3:\n        attempts += 1\n    return attempts\n",
    "expected": ["retry_timeout_change"]
  },
  {
    "name": "authorization guard",
    "old": "def allowed(user):\n    if user.is_admin:\n        return True\n    return False\n",
    "new": "def allowed(user):\n    if user.is_owner:\n        return True\n    return False\n",
    "expected": ["authorization_change"]
  },
  {
    "name": "output field",
    "old": "def result():\n    return {'old': 1}\n",
    "new": "def result():\n    return {'new': 1}\n",
    "expected": ["output_contract_change"]
  },
  {
    "name": "state assignment",
    "old": "def move():\n    state = 'old'\n    return state\n",
    "new": "def move():\n    state = 'new'\n    return state\n",
    "expected": ["state_transition_change"]
  },
  {
    "name": "dependency arguments",
    "old": "def fetch(client, x):\n    return client.fetch(x)\n",
    "new": "def fetch(client, x):\n    return client.fetch(x, strict=True)\n",
    "expected": ["dependency_interaction_change"]
  },
  {
    "name": "side effect",
    "old": "def finish(user):\n    return user\n",
    "new": "def finish(user):\n    notify(user)\n    return user\n",
    "expected": ["side_effect_change"]
  },
  {
    "name": "call ordering",
    "old": "def run():\n    first()\n    second()\n",
